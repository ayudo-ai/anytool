# anytool Production Environment
# Copy to .env and fill in values

# ── Required ─────────────────────────────────────────────────────────

# Token encryption key (MUST be stable — losing this = all tokens lost)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ANYTOOL_TOKEN_KEY=

# PostgreSQL
ANYTOOL_DB_HOST=
ANYTOOL_DB_PORT=5432
ANYTOOL_DB_NAME=metadb
ANYTOOL_DB_USER=
ANYTOOL_DB_PASSWORD=

# Google OAuth (platform-managed — all developers use these)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Server
PORT=8100
BASE_URL=https://api.anytool.dev

# Webhook signing secret
ANYTOOL_WEBHOOK_SECRET=

# ── Optional — add more providers ────────────────────────────────────

# Slack (create at https://api.slack.com/apps)
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=

# GitHub (create at https://github.com/settings/developers)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# HubSpot (create at https://developers.hubspot.com)
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=

# DocuSign (create at https://developers.docusign.com)
# DOCUSIGN_CLIENT_ID=
# DOCUSIGN_CLIENT_SECRET=
