# ── Anytool Environment ──────────────────────────────────────────────
# Copy to .env and fill in values

# ── Required ─────────────────────────────────────────────────────────

# Token encryption key (MUST be stable — losing this = all stored tokens lost)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ANYTOOL_TOKEN_KEY=

# PostgreSQL
ANYTOOL_DB_HOST=localhost
ANYTOOL_DB_PORT=5432
ANYTOOL_DB_NAME=anytool
ANYTOOL_DB_USER=anytool
ANYTOOL_DB_PASSWORD=password
ANYTOOL_DB_SCHEMA=anytool

# Server
PORT=8100
BASE_URL=http://localhost:8100

# ── OAuth Providers (add as needed) ──────────────────────────────────

# Google (https://console.cloud.google.com/apis/credentials)
# Redirect URI: http://localhost:8100/v1/connections/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Slack (https://api.slack.com/apps)
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=

# GitHub (https://github.com/settings/developers)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# HubSpot (https://developers.hubspot.com)
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=

# DocuSign (https://developers.docusign.com)
# DOCUSIGN_CLIENT_ID=
# DOCUSIGN_CLIENT_SECRET=

# ── Optional ─────────────────────────────────────────────────────────

# Webhook HMAC signing (signs outbound webhook payloads)
# ANYTOOL_WEBHOOK_SECRET=

# Stripe billing (for hosted platform only)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
